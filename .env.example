# .env.example — سیگنال هوش
# یک کپی به نام .env بساز و مقادیر واقعی را قرار بده.
# .env هرگز نباید commit شود (در .gitignore است).
#
# از فاز ۱ (۲۰۲۶-۰۷-۱۰) به بعد، سرور بدون این مقادیر اصلاً بالا نمی‌آید
# (server.js در startup چک می‌کند JWT_SECRET و NODE_INTERNAL_SECRET ست شده باشند).

# ── AI (OpenRouter) ──────────────────────────────────────
# ⚠️ این کلید قبلاً در فرانت (public/index.html) لو رفته بود — از داشبورد
# OpenRouter یک کلید جدید بساز و همین‌جا جایگزین کن.
OPENROUTER_KEY=

# ── تلگرام Bot API (news-bot.js polling — مسیر ثانویه، احتمالاً بلااستفاده چون ربات ادمین کانال‌ها نیست) ──
TELEGRAM_BOT_TOKEN=

# ── تلگرام Telethon/MTProto (news-listener.py — مسیر اصلی جمع‌آوری اخبار) ──
# ⚠️ هرگز این مقادیر را روی production عوض نکن مگر بخواهی session را از نو با کد SMS بسازی.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# ── سکرت داخلی بین Node و Telethon (هدر X-Internal-Secret) ──
# اگر عوض شود، باید همزمان هر دو پروسه pm2 (signal و news-listener) ری‌استارت شوند.
NODE_INTERNAL_SECRET=

# ── JWT ──────────────────────────────────────────────────
# اگر عوض شود، همه کاربران باید دوباره لاگین کنند (توکن‌های قبلی invalid می‌شوند).
JWT_SECRET=

# ── سوپرادمین پیش‌فرض (فقط اگر data/users.json خالی/نبود موقع اولین اجرا استفاده می‌شود) ──
ADMIN_MOBILE=
ADMIN_PASS=

# ── عمومی ────────────────────────────────────────────────
PORT=3001
CHROME_PATH=/usr/bin/google-chrome
NODE_ENV=production
